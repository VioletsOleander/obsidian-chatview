{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "obsidian-chatspace",
  "version": "1.0.0",
  "description": "Chat with LLM in obsidian",
  "author": "VioletsOleander",
  "license": "MIT",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "check-type": "tsc",
    "lint": "eslint .",
    "fmt": "dprint fmt",
    "check-fmt": "dprint check",
    "svelte-check": "svelte-check --tsconfig tsconfig.json"
  },
  "dependencies": {
    "obsidian": "latest",
    "openai": "^6.37.0"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "esbuild-svelte": "^0.9.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1",
    "typescript-svelte-plugin": "^0.3.52"
  }
}
